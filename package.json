{
  "name": "teams-generator",
  "private": true,
  "version": "1.6.0",
  "main": "index.js",
  "scripts": {
    "start": "cross-env APP_VARIANT=development expo start",
    "android": "cross-env APP_VARIANT=development expo run:android",
    "ios": "cross-env APP_VARIANT=development expo run:ios",
    "web": "cross-env APP_VARIANT=development expo start --web",
    "lint": "eslint . --config .eslintrc.production.js",
    "lint:fix": "eslint . --fix --config .eslintrc.production.js",
    "check": "tsc -b tsconfig.json",
    "test": "vitest",
    "test:ci": "vitest --run",
    "coverage": "vitest --run --coverage related",
    "coverage:all": "vitest --run --coverage",
    "build:development:android": "pnpm dlx eas-cli@latest build --platform android --profile development",
    "build:development:ios": "pnpm dlx eas-cli@latest build --platform ios --profile development",
    "build:development:ios:simulator": "pnpm dlx eas-cli@latest build --platform ios --profile development-simulator",
    "build:preview:android": "pnpm dlx eas-cli@latest build --platform android --profile preview",
    "build:staging:android": "pnpm dlx eas-cli@latest build --platform android --profile staging",
    "build:production:android": "pnpm dlx eas-cli@latest build --platform android --profile production --auto-submit",
    "build:production:ios": "pnpm dlx eas-cli@latest build --platform ios --profile production --auto-submit",
    "build:production": "pnpm dlx eas-cli@latest build --profile production --auto-submit",
    "update:preview": "cross-env APP_VARIANT=preview pnpm dlx eas-cli@latest update --auto --platform android --channel preview",
    "update:staging": "cross-env APP_VARIANT=staging pnpm dlx eas-cli@latest update --auto --platform android --channel staging",
    "update:production": "cross-env APP_VARIANT=production pnpm dlx eas-cli@latest update --auto --platform android --channel production"
  },
  "dependencies": {
    "@effect/typeclass": "^0.40.0",
    "@expo/dom-webview": "^57.0.0",
    "@expo/material-symbols": "^0.1.1",
    "@expo/ui": "~57.0.3",
    "@expo/vector-icons": "15.1.1",
    "@fp-ts/optic": "^0.25.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@react-native-async-storage/async-storage": "~2.2.0",
    "cross-env": "^10.1.0",
    "effect": "3.21.4",
    "expo": "^57.0.2",
    "expo-application": "~57.0.0",
    "expo-constants": "~57.0.3",
    "expo-dev-client": "~57.0.5",
    "expo-device": "~57.0.0",
    "expo-document-picker": "~57.0.0",
    "expo-file-system": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-linking": "~57.0.1",
    "expo-localization": "~57.0.0",
    "expo-router": "~57.0.3",
    "expo-sharing": "~57.0.2",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-updates": "~57.0.6",
    "fast-text-encoding": "^1.0.6",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-google-mobile-ads": "16.3.4",
    "react-native-reanimated": "~4.5.0",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-worklets": "0.10.0",
    "use-sync-external-store": "^1.6.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/runtime": "^7.28.2",
    "@changesets/cli": "^2.31.0",
    "@cspell/dict-pt-br": "^2.4.2",
    "@expo/config-types": "57.0.1",
    "@types/benchmark": "^2.1.5",
    "@types/lodash.throttle": "^4.1.9",
    "@types/react": "~19.2.17",
    "@types/use-sync-external-store": "^1.5.0",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "@vitest/coverage-v8": "^4.1.9",
    "benchmark": "^2.1.4",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "prettier": "^3.9.4",
    "rimraf": "^6.1.3",
    "tsutils": "^3.21.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "enabled": true,
        "listUnknownPackages": true,
        "exclude": [
          "@fp-ts/optic",
          "@paralleldrive/cuid2",
          "cross-env",
          "effect",
          "fast-text-encoding",
          "use-sync-external-store"
        ]
      }
    }
  }
}
